digraph
{
   layout=dot;
   rankdir="TB";
   overlap = scale;
   splines=ortho; 
   node[shape=record; style=filled; fillcolor=white];

   
   A; B; C; D; CC; E; F; G; H; I; J; K; L;

   edge[style=invis];
   A -> B -> C -> D;
   E -> F -> G -> H;
   I -> J -> K -> L;
   M -> N -> O -> P;
   
//   A -> E -> I -> M;
//   B -> F -> J -> N;
//   C -> G -> K -> O;
//   D -> H -> L -> P;
   
   edge[constraint=false; style=solid];
//   A -> D -> G;

   subgraph cluster_column1
   {
      bgcolor=lightgray;
      penwidth=0;
      A; B; C; D;
   }
   
   subgraph cluster_column2 {
   	style=invis;
   	E; F; G; H;
   }
   
   subgraph cluster_column3 {
   	style=invis;
   	I; J; K;L;
   }
   
   subgraph cluster_column4 {
   	style=invis;
   	M;N;O;P;
   }
   
   A [label="START: You want to be\na contributor";style="filled,bold"]
   B [label="Contributor signs\nthe ECA"];
   C [style=invis]
   D [label="Submit pull requests"];
   CC [label="Significant\nContributor?"; shape=diamond;fontsize=8];
   E [label="Project Team elects\nyou as a committer\non a specification project";style="filled,bold"];
   F [label="Are you a student,\nself-employed,\nor unemployed?", shape=diamond;fontsize=8];
   G [label="Committer signs\nthe IWGPA"];
   H [style=invis];
   I [style=invis];
   J [label="Is your employer\na member of the\nEclipse Foundation?"; shape=diamond;fontsize=8];
   K [label="Employer signs\nthe Consent Agreement\nand Committer signs\nthe IWGPA"];
   L [label="Congratulations,\nyou’re a committer!"; style="rounded,filled,bold"];
   M [style=invis];
   N [label="Is your employer\na participant in\nthe working group?"; shape=diamond;fontsize=8];
   O [style=invis];
   P [style=invis];
   
  A -> B;
  B -> D;
  D -> CC;
  CC -> D [label="No"];
  CC-> E [xlabel="Yes"];
  E -> F;
  F -> G [label="Yes"];
  G -> L;
  
  F -> J [label="No"];
  J -> K [label="No"];
  K -> L;
  
  J -> N [label="Yes"];
  N -> K [xlabel="No "];
  N -> L [xlabel="Yes "];
}