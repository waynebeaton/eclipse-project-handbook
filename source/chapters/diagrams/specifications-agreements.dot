digraph {
	// Graph properties
	bgcolor=transparent
	
    graph [ranksep="0.25", nodesep="0.25"]
    
	// Nodes that define the key points in the process
	node [shape=box;style=filled;fillcolor=white;fontsize=12;group=g1]
	
	start [label="Project Team elects\nyou as a committer"; style="filled,bold"];
	individual_wgpa [label=<<b>You</b> sign<br/>the IWGPA>];
	individual_membership [label=<<b>You</b> sign the<br/>Member Agreement>];
	individual_employer_consent [label=<Your <b>Employer</b> signs the<br/>Employer Consent Agreement for<br/>Eclipse Specification Projects>];
	individual_ica [label=<<b>You</b> sign<br/>the ICA>];
	employed_individual_membership [label=<<b>You</b> sign the<br/>Member Agreement>];
	employed_ica [label=<<b>You</b> sign<br/>the ICA>];
	employed_iwgpa [label=<<b>You</b> sign<br/>the IWGPA>];
	final [label="Congratulations,\nyou're a Committer"; style="rounded,filled,bold"];
	
	node [shape=diamond;style=filled;fillcolor=white;fontsize=10;group=g1];
	
	is_self_employed [label="Are you a student,\nself-employed,\nor unemployed?"];
	employer_is_member [label="Is your employer\na member of the\nEclipse Foundation?"];
	employer_is_participant [label="Is your employer\na participant in\nthe working group?"];
	employer_has_mcca [label="Has your employer\nsigned the MCCA?"];
	individual_has_ica [label="Have you signed\nthe ICA?"];
	individual_is_member [label="Are you a member of\nthe Eclipse Foundation?"];
		
	start -> is_self_employed;
	
	is_self_employed -> individual_has_ica [label="Yes"];
	is_self_employed -> employer_is_member [label="No"];
	
	individual_has_ica -> individual_is_member [label="Yes"];
	individual_has_ica -> individual_ica [label="No"];
	
	individual_is_member -> individual_wgpa [label="Yes"];
	individual_is_member -> individual_membership [label="No"];
	
	individual_ica -> individual_membership;
	individual_membership -> individual_wgpa;
	individual_wgpa -> final;
		
	employer_is_member -> employer_is_participant [label="Yes"];
	employer_is_member -> employed_individual_membership [label="No"];
	
	employed_individual_membership -> employed_iwgpa;
	employed_iwgpa -> employed_ica;
	employed_ica -> individual_employer_consent;
	
	employer_is_participant -> employer_has_mcca [label="Yes"];
	employer_is_participant -> employed_iwgpa [label="No"];
		
	employer_has_mcca -> final [label="Yes"];
	employer_has_mcca -> employed_ica [label="No"];
		
	individual_employer_consent -> final;
}